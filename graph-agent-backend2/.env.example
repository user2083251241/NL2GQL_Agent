# ============================================
# HugeGraph 数据库配置
# ============================================
HUGEGRAPH_HOST=127.0.0.1
HUGEGRAPH_PORT=8080
HUGEGRAPH_USER=admin
HUGEGRAPH_PWD=admin
HUGEGRAPH_GRAPH=hugegraph
HUGEGRAPH_GRAPHSPACE=

# ============================================
# LLM API 配置（以OpenAI为例）
# ============================================
# OpenAI API密钥（必需）
OPENAI_API_KEY=your_openai_api_key_here

# 使用的模型（可选，默认gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo

# 自定义API地址（可选，用于代理或国内中转）
# 例如：OPENAI_BASE_URL=https://api.openai.com/v1
# 国内中转示例：OPENAI_BASE_URL=https://api.xxx.com/v1
OPENAI_BASE_URL=

# ============================================
# LangChain 配置
# ============================================
# 是否启用详细日志（True/False）
LANGCHAIN_VERBOSE=False

# ============================================
# Flask 应用配置
# ============================================
# 调试模式（True/False）
DEBUG=True

# 服务器监听地址
HOST=0.0.0.0

# 服务器端口
PORT=5000
